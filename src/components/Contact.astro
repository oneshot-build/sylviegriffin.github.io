---
import Section from './Section.astro';
---

<Section>
  <div class="contact-container">
    <div class="contact-content" data-reveal>
      <h2>Contact</h2>
      <p class="contact-description">
        Ready to start your journey towards a more fulfilling life? I'd love to hear from you. 
        Whether you have questions about my coaching approach or want to book a session, 
        I'm here to support you.
      </p>
    </div>

    <div class="contact-form-container" data-reveal>
      <form method="POST" action="/api/contact" class="contact-form">
        <div class="form-group">
          <label for="name">Name *</label>
          <input 
            type="text" 
            id="name" 
            name="name" 
            required 
            placeholder="Your full name"
          />
        </div>

        <div class="form-group">
          <label for="email">Email *</label>
          <input 
            type="email" 
            id="email" 
            name="email" 
            required 
            placeholder="your.email@example.com"
          />
        </div>

        <div class="form-group">
          <label for="phone">Phone</label>
          <input 
            type="tel" 
            id="phone" 
            name="phone" 
            placeholder="+1 (555) 123-4567"
          />
        </div>

        <div class="form-group">
          <label for="subject">Subject *</label>
          <select id="subject" name="subject" required>
            <option value="">Select a topic</option>
            <option value="1on1-coaching">1:1 Life Coaching</option>
            <option value="yoga-sessions">Yoga Sessions</option>
            <option value="corporate-workshops">Corporate Workshops</option>
            <option value="reiki-healing">Reiki Healing</option>
            <option value="general-inquiry">General Inquiry</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div class="form-group">
          <label for="message">Message *</label>
          <textarea 
            id="message" 
            name="message" 
            required 
            rows="5"
            placeholder="Tell me about what you're looking for and how I can support you..."
          ></textarea>
        </div>

        <button type="submit" class="submit-button">
          <span>Send Message</span>
          <svg class="submit-icon" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </button>
      </form>

      <div class="contact-info">
        <div class="info-item">
          <strong>Response Time</strong>
          <p>I typically respond within 24 hours</p>
        </div>
        <div class="info-item">
          <strong>Confidentiality</strong>
          <p>All communications are treated with complete confidentiality</p>
        </div>
      </div>
    </div>
  </div>
</Section>

<style>
  .contact-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  @media (min-width: 768px) {
    .contact-container {
      grid-template-columns: 1fr 1.2fr;
      gap: var(--space-2xl);
    }
  }

  .contact-content h2 {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: var(--weight-semibold);
    margin-bottom: var(--space-md);
    color: var(--text-primary);
    line-height: var(--leading-tight);
  }

  .contact-description {
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    color: var(--text-secondary);
    margin-bottom: var(--space-lg);
  }

  .contact-form-container {
    background: var(--bg-elevated);
    border-radius: var(--radius-xl);
    padding: var(--space-lg);
    box-shadow: var(--shadow-md);
    border: 1px solid var(--border);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }

  .form-group label {
    font-weight: var(--weight-medium);
    color: var(--text-primary);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: var(--space-sm);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    font-size: var(--text-base);
    background: var(--bg-primary);
    color: var(--text-primary);
    transition: all var(--duration-fast) var(--ease-calm);
    font-family: var(--font-body);
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-muted);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
    font-family: inherit;
  }

  .submit-button {
    background: var(--cta);
    color: var(--bg-elevated);
    border: none;
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius-md);
    font-weight: var(--weight-semibold);
    font-size: var(--text-base);
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-calm);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    margin-top: var(--space-2xs);
    font-family: var(--font-body);
  }

  .submit-button:hover {
    background: var(--cta-hover);
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  .submit-button:active {
    transform: translateY(0);
  }

  .submit-icon {
    width: 1.25rem;
    height: 1.25rem;
    transition: transform var(--duration-fast) var(--ease-calm);
  }

  .submit-button:hover .submit-icon {
    transform: translateX(4px);
  }

  .contact-info {
    display: grid;
    gap: var(--space-md);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--border);
  }

  @media (min-width: 640px) {
    .contact-info {
      grid-template-columns: 1fr 1fr;
    }
  }

  .info-item strong {
    color: var(--text-primary);
    font-weight: var(--weight-semibold);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    display: block;
    margin-bottom: var(--space-2xs);
  }

  .info-item p {
    color: var(--text-secondary);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    margin: 0;
  }

  /* Form validation states */
  .form-group input:invalid:not(:placeholder-shown),
  .form-group select:invalid:not(:placeholder-shown),
  .form-group textarea:invalid:not(:placeholder-shown) {
    border-color: #ef4444;
  }

  .form-group input:valid:not(:placeholder-shown),
  .form-group select:valid:not(:placeholder-shown),
  .form-group textarea:valid:not(:placeholder-shown) {
    border-color: #10b981;
  }

  /* Reveal animation */
  [data-reveal] {
    opacity: 0;
    transform: translateY(2rem);
    transition: all var(--duration-slowest) var(--ease-out-expo);
  }

  [data-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Stagger the reveal animations */
  .contact-content[data-reveal] {
    transition-delay: 0ms;
  }

  .contact-form-container[data-reveal] {
    transition-delay: 200ms;
  }

  /* Dark theme adjustments are handled by CSS custom properties */
</style>